# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
VITE_STRAVA_CLIENT_ID=

# Google Maps Platform
# Server key (Isochrones proxy): needs Isochrones API.
# Browser key (VITE_): needs Maps JS, Air Quality, Places APIs; restrict by referrer.
GMP_SERVER_API_KEY=
VITE_GMP_API_KEY=
VITE_ISOCHRONES_GMP_API_KEY=

# Contact form + email list (optional locally)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
# Resend audience that /api/subscribe adds contacts to (create in the Resend
# dashboard under Audiences; broadcasts to the list are composed there too).
RESEND_AUDIENCE_ID=

# Private writer (optional locally)
PORTFOLIO_WRITER_PASSWORD=
GITHUB_CONTENT_TOKEN=

# Analytics (optional public configuration)
ANALYTICS_MEASUREMENT_ID=

# Gemini (optional; server-only contact classification)
# Never prefix this with VITE_. Configure the production value through
# Secret Manager as GEMINI_API_KEY=gemini-api-key:latest on Cloud Run.
GEMINI_API_KEY=
