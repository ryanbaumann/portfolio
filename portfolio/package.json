{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "description": "Ryan Baumann's portfolio: a zero-dependency static site over a flat-file markdown CMS.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:writer": "BASE_PATH=/writer/ PORTFOLIO_WRITER_MODE=true PORTFOLIO_DIST_DIR=writer-dist node build.mjs",
    "dev": "node build.mjs && node serve.mjs",
    "clean": "rm -rf dist",
    "test": "node --test test/*.test.mjs && npm run build"
  },
  "engines": {
    "node": ">=20"
  }
}
